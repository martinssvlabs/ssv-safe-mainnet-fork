# Ethereum mainnet JSON-RPC endpoint used for fork simulation
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Safe owner private keys (0x-prefixed, 64 hex chars)
# The script derives owner addresses from these keys.
OWNER1_PK=0xYOUR_PRIVATE_KEY_1
OWNER2_PK=0xYOUR_PRIVATE_KEY_2

# Multisig threshold for the Safe
# Must be between 1 and the number of owners.
# If omitted, the script defaults to 2.
SAFE_THRESHOLD=2

# Safe address to fund (set after deployment)
SAFE_ADDRESS=0xYOUR_SAFE_ADDRESS

# SSV network/token funding variables
# SSV_CONTRACT may be used to discover token() on some deployments.
SSV_CONTRACT=0xYOUR_SSV_NETWORK_CONTRACT
# Prefer setting SSV_TOKEN explicitly to avoid ABI/version mismatches.
SSV_TOKEN=0xYOUR_SSV_TOKEN_CONTRACT
SSV_WHALE=0xADDRESS_HOLDING_SSV_ON_FORK
SSV_FUND_AMOUNT=1000

# Safe-based allowance management
# Owner key used to sign/approve Safe txs (falls back to OWNER1_PK if omitted)
SAFE_APPROVER_PK=0xYOUR_SAFE_OWNER_PRIVATE_KEY
# Human-readable SSV allowance amount to grant to SSV_CONTRACT
SSV_ALLOWANCE_AMOUNT=1000000000
